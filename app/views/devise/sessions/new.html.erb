<div class="flex flex-col items-center justify-center min-h-screen">
  <div class="bg-stone-200 p-8 rounded w-96">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="mb-4">
        <%= f.label :email, "メール", class: "block mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-3 py-2 rounded bg-stone-50" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "パスワード", class: "block mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full px-3 py-2 rounded bg-stone-50" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-6 flex items-center gap-2">
          <%= f.check_box :remember_me, class: "cursor-pointer" %>
          <%= f.label :remember_me, "ログイン状態を保持する", class: "text-sm cursor-pointer" %>
        </div>
      <% end %>

      <div class="text-center mb-4">
        <%= f.submit "ログイン", class: "bg-gray-700 text-white px-8 py-2 rounded cursor-pointer" %>
      </div>

    <% end %>

    <div class="text-center mt-4">
      <%= link_to "新規ユーザー登録", new_user_registration_path,
          class: "bg-gray-500 text-white px-8 py-2 rounded" %>
    </div>
  </div>
</div>