<%# ログイン画面に戻るボタン（左上固定） %>
<div class="absolute top-6 left-6">
  <%= link_to new_user_session_path,
        class: "flex items-center gap-2 bg-gray-700 text-white px-4 py-2 rounded-lg text-sm" do %>
    ← ログイン画面に戻る
  <% end %>
</div>

<div class="flex flex-col items-center justify-center min-h-screen">
  <div class="bg-stone-200 p-8 rounded w-96">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :name, "ユーザーネーム", class: "block mb-1" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name",
            class: "w-full px-3 py-2 rounded bg-stone-50" %>
      </div>

      <div class="mb-4">
        <%= f.label :email, "メール", class: "block mb-1" %>
        <%= f.email_field :email, autocomplete: "email",
            class: "w-full px-3 py-2 rounded bg-stone-50" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "パスワード", class: "block mb-1" %>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full px-3 py-2 rounded bg-stone-50" %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, "パスワード（確認）", class: "block mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full px-3 py-2 rounded bg-stone-50" %>
      </div>

      <div class="text-center">
        <%= f.submit "登録", class: "bg-gray-700 text-white px-8 py-2 rounded cursor-pointer" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>