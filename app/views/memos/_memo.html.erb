<%# dom_idとclassを1つのdivにまとめる %>
<div id="<%= dom_id(memo) %>"
     class="bg-stone-100 rounded-lg p-4"
     data-action="click->memo-select#toggle">

  <%# チェックボックスエリア（最初は非表示） %>
  <div data-memo-select-target="checkboxArea" class="hidden flex justify-end mb-2">
    <input type="checkbox"
           value="<%= memo.id %>"
           data-memo-select-target="checkbox"
           class="w-4 h-4" />
  </div>

  <%# メモ本文 %>
  <p class="whitespace-pre-wrap"><%= memo.content %></p>

  <%# 操作ボタン %>
  <div class="flex justify-end items-center gap-4 mt-3">

    <% if creation_id.present? %>
      <%# data: { turbo: true } でTurbo Streamのレスポンスを受け取れるようにする %>
      <%= button_to "プロットに追加",
            from_memo_creation_plot_blocks_path(creation_id),
            params: { memo_id: memo.id },
            method: :post,
            data: { turbo: true },
            class: "text-blue-500 text-sm cursor-pointer bg-transparent border-none" %>
    <% else %>
      <span class="text-gray-300 text-sm">プロットに追加</span>
    <% end %>

    <%# 編集ボタン %>
    <button data-action="click->memo-edit#open"
            data-memo-id="<%= memo.id %>"
            data-memo-content="<%= memo.content %>"
            data-creation-id="<%= creation_id %>"
            class="text-gray-500 text-sm cursor-pointer">
      編集
    </button>

    <%# 削除ボタン %>
    <%= link_to "削除", memo_path(memo),
          data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
          class: "text-gray-500 text-sm" %>

  </div>
</div>