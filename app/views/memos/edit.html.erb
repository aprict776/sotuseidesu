<div class="flex flex-col items-center justify-center min-h-screen">
  <div class="w-full max-w-2xl p-6">
    <h1 class="text-xl font-bold mb-6">メモを編集</h1>

    <%= form_with model: @memo, url: memo_path(@memo), method: :patch do |f| %>
      <div class="mb-4">
        <%= f.text_area :content, rows: 6,
            class: "w-full px-4 py-3 rounded-lg bg-stone-100 resize-none" %>
      </div>
      <div class="flex justify-between">
        <%= link_to "キャンセル", memos_path, class: "text-gray-500" %>
        <%= f.submit "更新する", class: "bg-gray-700 text-white px-6 py-2 rounded cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>