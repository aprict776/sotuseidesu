<%# メモ編集モーダル %>
<div data-memo-edit-target="modal"
  data-action="click->memo-edit#closeOnBackdrop"
  class="hidden fixed inset-0 bg-black/40 flex items-center justify-center z-50">

  <div class="bg-stone-50 rounded-xl p-8 w-[600px] shadow-lg">
    <p class="text-lg font-bold mb-6">メモを編集</p>

    <%= form_with url: "#", method: :patch, data: { "memo-edit-target": "form" } do |f| %>

      <%= f.text_area :content,
            rows: 6,
            data: { "memo-edit-target": "content" },
            name: "memo[content]",
            class: "w-full px-4 py-3 rounded-lg bg-stone-100 resize-none mb-6" %>

      <div class="flex justify-between items-center">
        <button type="button"
                data-action="click->memo-edit#close"
                class="text-gray-500 cursor-pointer">
          キャンセル
        </button>
        <%= f.submit "更新する",
              class: "bg-gray-700 text-white px-6 py-2 rounded cursor-pointer" %>
      </div>

    <% end %>
  </div>
</div>