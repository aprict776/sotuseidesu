<div class="flex h-screen">
  <%# メモ投稿・一覧エリア %>
  <div class="flex-1 flex flex-col p-6 overflow-y-auto">

    <%# メモ投稿フォーム %>
    <%= form_with model: @memo, url: memos_path do |f| %>
      <div class="mb-4">
        <%= f.text_area :content, rows: 4,
            placeholder: "アイデアをメモしよう...",
            class: "w-full px-4 py-3 rounded-lg bg-stone-100 resize-none" %>
      </div>
      <div class="flex justify-end">
        <%= f.submit "メモる", class: "bg-gray-700 text-white px-6 py-2 rounded-full cursor-pointer" %>
      </div>
    <% end %>

     <%# メモ削除 %>
    <div class="mt-6 flex flex-col gap-4">
      <% @memos.each do |memo| %>
        <div class="bg-stone-100 rounded-lg p-4">
          <p class="whitespace-pre-wrap"><%= memo.content %></p>
          <div class="flex justify-end mt-3">
            <%= button_to "削除", memo_path(memo), method: :delete,
                data: { turbo_confirm: "削除しますか？" },
                class: "text-gray-500 text-sm bg-transparent border-0 cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>