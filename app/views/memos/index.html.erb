<div class="flex h-screen overflow-hidden" data-controller="creation">

  <%# 左パネル：作品一覧 %>
  <div class="w-64 bg-gray-700 text-white flex flex-col">

    <%# ユーザー名 %>
    <div class="px-4 py-3 border-b border-gray-600">
      <span class="font-bold"><%= current_user.name %></span>
    </div>

    <%# 作品一覧ヘッダー %>
    <div class="flex justify-between items-center px-4 py-3 border-b border-gray-600">
      <span class="text-sm text-gray-300">作品一覧</span>

      <%= form_with url: creations_path, class: "flex items-center gap-1" do |f| %>
        <%= hidden_field_tag :creation_id, params[:creation_id] %>
        <%= f.text_field :title,name: "creation[title]",placeholder: "新しい作品",class: "w-24 px-2 py-1 rounded bg-gray-600 text-white text-xs" %>
        <%= f.submit "+", class: "bg-gray-500 px-2 py-1 rounded cursor-pointer" %>
      <% end %>
    </div>

    <%# 作品一覧 %>
    <div class="flex-1 overflow-y-auto">
      <% @creations.each do |creation| %>
       <%= render creation %>  <%# _creation.html.erb（パーシャファイル）を呼び出す %>
      <% end %>
    </div>
  </div>  <%# ← 左パネルここで閉じる %>

  <%# メモ投稿・一覧エリア %>
  <div class="flex-1 flex flex-col p-6 overflow-y-auto scrollbar-hide">

    <%= form_with model: @memo, url: memos_path do |f| %>
    <%= hidden_field_tag :creation_id, params[:creation_id] %>  <%# ID %>
      <%# メモ投稿フォーム %>
      <div class="mb-4">
        <%= f.text_area :content, rows: 4,
            placeholder: "アイデアをメモしよう...",
            class: "w-full px-4 py-3 rounded-lg bg-stone-100 resize-none" %>
      </div>
      <div class="flex justify-end">
        <%= f.submit "メモる", class: "bg-gray-700 text-white px-6 py-2 rounded-full cursor-pointer" %>
      </div>
    <% end %>

    <%# メモ一覧 %>
    <%# data-controller="memo-edit" でStimulusコントローラを起動 %>
      <div class="mt-6 flex flex-col gap-4" data-controller="memo-edit">
        <%# render collection: で_memo.html.erbを1件ずつ呼び出す %>
        <%= render partial: "memo", collection: @memos, as: :memo %>
        <%# 編集モーダルをパーシャルで呼び出す %>
        <%= render "memo_edit_modal" %>
      </div>
    </div>

  <%# 右パネル：プロットブロック %>
  <div class="w-72 bg-stone-200 flex flex-col" data-controller="plot-block">

  <%# パネルヘッダー %>
  <div class="px-4 py-3 border-b border-stone-300 flex justify-between items-center">
    <span class="font-bold" data-creation-target="title">
      <%= @selected_creation ? @selected_creation.title : "プロット" %>
    </span>

    <% if @selected_creation %>
      <%# + ボタン：クリックでモーダルを開く %>
      <button data-action="click->plot-block#open"
              class="text-gray-600 text-xl font-light leading-none cursor-pointer">
        ＋
      </button>
    <% end %>
  </div>

  <div class="flex-1 overflow-y-auto p-4">
    <% if @selected_creation %>

      <%# プロットブロック一覧 %>
      <%= render partial: "plot_blocks/plot_block",
                 collection: @selected_creation.plot_blocks,
                 as: :plot_block %>

      <% if @selected_creation.plot_blocks.empty? %>
        <p class="text-gray-400 text-sm text-center mt-4">まだブロックがありません</p>
      <% end %>

    <% else %>
      <p class="text-gray-500 text-sm">作品を選択してください</p>
    <% end %>
  </div>

  <%# モーダル（最初はhidden） %>
  <% if @selected_creation %>
    <%# 背景オーバーレイ：クリックで閉じる %>
    <div data-plot-block-target="modal"
         data-action="click->plot-block#closeOnBackdrop"
         class="hidden fixed inset-0 bg-black/40 flex items-center justify-center z-50">

      <%# モーダル本体 %>
      <div class="bg-stone-50 rounded-xl p-8 w-96 shadow-lg">
        <p class="text-lg mb-6">ブロックのタイトル</p>
        <%= form_with url: creation_plot_blocks_path(@selected_creation), method: :post do |f| %>

          <%# タイトル入力 %>
          <%= f.text_field :title,
                name: "plot_block[title]",
                placeholder: "",
                autofocus: true,
                class: "w-full border-b border-gray-400 bg-transparent py-2 text-sm outline-none mb-6" %>

          <%# contentは空文字で送る（後から編集する想定） %>
          <%= f.hidden_field :content, value: "", name: "plot_block[content]" %>

          <div class="flex justify-end gap-3">
            <%# キャンセルボタン %>
            <button type="button"
                    data-action="click->plot-block#close"
                    class="px-4 py-2 text-sm text-gray-600 cursor-pointer">
              キャンセル
            </button>

            <%# 作成ボタン %>
            <%= f.submit "作成",
                  class: "px-6 py-2 bg-gray-700 text-white text-sm rounded-full cursor-pointer" %>
          </div>

        <% end %>
      </div>

    </div>
  <% end %>

</div>