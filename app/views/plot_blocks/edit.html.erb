<%# Turbo Streamで差し替えられる通知エリア（保存ボタン用） %>
<div id="notice"></div>

<div class="flex h-screen overflow-hidden">

  <%# 左パネル %>
  <div class="w-64 bg-gray-700 text-white flex flex-col">
    <%# ユーザーアイコン（クリックでログアウトメニュー表示） %>
    <%= render "layouts/user_menu" %>
    <div class="flex justify-between items-center px-4 py-3 border-b border-gray-600">
      <span class="text-sm text-gray-300">作品一覧</span>
      <%= form_with url: creations_path, class: "flex items-center gap-1" do |f| %>
        <%= hidden_field_tag :creation_id, @creation.id %>
        <%= f.text_field :title, name: "creation[title]", placeholder: "新しい作品",
              class: "w-24 px-2 py-1 rounded bg-gray-600 text-white text-xs" %>
        <%= f.submit "+", class: "bg-gray-500 px-2 py-1 rounded cursor-pointer" %>
      <% end %>
    </div>
    <div class="flex-1 overflow-y-auto">
      <% current_user.creations.order(created_at: :desc).each do |creation| %>
        <%= render creation %>
      <% end %>
    </div>
  </div>

  <%# 中央：執筆エリア %>
  <div class="flex-1 flex flex-col overflow-y-auto bg-[#f5f0e8]">

    <%# 執筆フォーム（Turbo StreamでAjax保存） %>
    <%= form_with model: @plot_block,
                  id: "writing-form",
                  class: "flex flex-col h-full" do |f| %>

      <%# 戻るボタン：クリック時にフォームをsubmitしてからmemos_pathへ %>
      <div class="p-4">
        <%= link_to "←",
              memos_path(creation_id: @creation.id),
              id: "back-button",
              class: "text-gray-500 text-sm hover:text-gray-700" %>
      </div>

      <div class="max-w-3xl mx-auto w-full px-8 py-6 flex-1">

        <%# タイトル入力欄 %>
        <%= f.text_field :title,
              placeholder: "ブロックタイトル",
              class: "w-full text-4xl font-bold bg-transparent border-none outline-none
                      mb-8 text-gray-800 placeholder-gray-300 cursor-text" %>

        <%# 本文テキストエリア %>
        <%= f.text_area :content,
              placeholder: "テキストを入力...",
              rows: 20,
              class: "w-full bg-transparent border-none outline-none resize-none
                      text-gray-700 text-base leading-relaxed placeholder-gray-300" %>
      </div>

      <%# 保存ボタン（右下固定） %>
      <div class="fixed bottom-8 right-8">
        <%= f.submit "執筆内容を保存",
              class: "bg-gray-700 text-white px-6 py-3 rounded-lg
                      shadow-lg hover:bg-gray-800 cursor-pointer text-sm" %>
      </div>

    <% end %>
  </div>

</div>

<%# 戻るボタンのJS：フォームをsubmitしてから遷移 %>
<script>
  document.getElementById("back-button").addEventListener("click", function(e) {
    e.preventDefault();
    const form = document.getElementById("writing-form");
    const url  = this.href;

    fetch(form.action, {
      method: "PATCH",
      body: new FormData(form),
      redirect: "manual", // リダイレクトを自動追跡させず、ホーム画面の二重読み込みを防ぐ
      headers: {
        "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content,
        // HTMLレスポンスを明示することでformat.htmlが呼ばれflash[:notice]が渡される
        "Accept": "text/html"
      }
    }).then(() => { window.location.href = url; });
  });
</script>